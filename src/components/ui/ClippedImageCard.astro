---
const { title, description, image, imageAlt } = Astro.props;
---

<div
  class="flex h-90 w-full items-center justify-between rounded-2xl bg-white shadow-lg"
>
  <div class="ml-4 flex flex-col gap-2 text-left">
    <h3 class="text-2xl font-bold">{title}</h3>
    <p>{description}</p>
  </div>
  <div class="h-full w-full">
    <img
      src={image?.src}
      alt={imageAlt}
      loading="lazy"
      class="h-full w-full rounded-2xl object-cover [clip-path:polygon(35%_0,100%_0,100%_100%,10%_100%)]"
    />
  </div>
</div>
