---
const { title, description, bgColor, titleColor, descriptionColor } =
  Astro.props;
---

<div
  class={`flex h-50 w-full max-w-100 flex-col items-center justify-center gap-4 rounded-2xl p-4 text-center shadow-lg ${bgColor}`}
>
  <h3 class={`text-2xl ${titleColor}`}>{title}</h3>
  <p class={`${descriptionColor}`}>{description}</p>
</div>
