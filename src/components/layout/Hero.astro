---
import Typewriter from "../../lib/utils/Typewriter.jsx";
const { heroText, typewriterText, typewriterSpeed, typewriterPause } =
  Astro.props;
---

<section
  class="flex h-78 items-center justify-center bg-linear-to-r from-black from-70% via-green-700 via-85% to-purple-700 to-100%"
>
  <div class="mx-auto max-w-7xl px-8 py-4 text-center text-white">
    <div class="flex flex-col items-center gap-4">
      <h1 class="text-4xl font-bold md:text-5xl">
        {heroText}
      </h1>
      <p class="text-2xl md:text-3xl">
        <Typewriter
          client:load
          text={typewriterText}
          speed={typewriterSpeed}
          pause={typewriterPause}
        />
      </p>
    </div>
  </div>
</section>
