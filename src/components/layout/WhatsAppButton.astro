---
import WhatsAppIcon from "../../assets/icons/whatsapp.svg";
---

<a
  href="https://wa.me/523332334293"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Enviar mensaje por WhatsApp"
  class="bg-primary group fixed right-6 bottom-6 z-50 flex items-center overflow-hidden rounded-full no-underline transition-all duration-500 ease-in-out md:right-8 md:bottom-8"
>
  <span
    class="max-w-0 overflow-hidden p-0 whitespace-nowrap text-white opacity-0 transition-all duration-500 ease-in-out group-hover:max-w-xs group-hover:p-2 group-hover:pr-1 group-hover:opacity-100 group-focus:max-w-xs group-focus:p-2 group-focus:pr-1 group-focus:opacity-100 group-active:max-w-xs group-active:p-2 group-active:pr-1 group-active:opacity-100"
    >Enviar WhatsApp</span
  >
  <div class="rounded-full bg-[#25D366]">
    <img
      src={WhatsAppIcon.src}
      alt=""
      aria-hidden="true"
      class="h-14 w-14 object-contain p-2"
    />
  </div>
</a>
