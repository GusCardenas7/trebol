---
import RightArrow from "../../assets/icons/rightArrow.svg";
const { bannerTitle, bannerText, bannerButtonText } = Astro.props;
---

<section class="flex h-90 items-center justify-center bg-[#101566]">
  <div class="mx-auto max-w-7xl px-8 py-4 text-center text-white">
    <div class="flex flex-col items-center gap-4">
      <h3 class="text-4xl font-bold md:text-5xl">
        {bannerTitle}
      </h3>
      <p class="text-2xl md:text-3xl">{bannerText}</p>
      <button
        class="mt-2 flex w-full max-w-80 cursor-pointer items-center justify-center gap-2 rounded-2xl bg-white p-4 text-lg text-[#101566] transition-opacity duration-300 hover:opacity-80 active:scale-95"
        >{bannerButtonText}
        <img
          src={RightArrow.src}
          alt=""
          aria-hidden="true"
          class="h-6 w-6 object-contain"
        /></button
      >
    </div>
  </div>
</section>
